page {
  background: #f7f6f3;
  color: #37352f;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.page-wrap {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border: 1px solid #e9e9e7;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.field,
.picker-field {
  margin-top: 10rpx;
  border: 1px solid #e5e7eb;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #fff;
}

.btn-stack {
  margin-top: 10rpx;
}

.list-item {
  border-top: 1px solid #f1f2ef;
  padding: 14rpx 0;
}

button {
  border-radius: 12rpx;
  font-weight: 500;
  border: 1px solid #e6e6e4;
  background: #ffffff;
  color: #37352f;
}

.btn-primary {
  background: #2f2f2f;
  color: #ffffff;
  border: 1px solid #2f2f2f;
  box-shadow: none;
}

.btn-danger {
  background: #e03e3e;
  color: #ffffff;
  border: 1px solid #e03e3e;
  box-shadow: none;
}

.hint {
  color: #787774;
  font-size: 24rpx;
}
