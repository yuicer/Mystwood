<view style="padding:24rpx"><view class="card"><view style="font-size:30rpx;font-weight:600">创建任务</view><picker range="{{b}}" range-key="name" bindchange="{{c}}" style="margin-top:12rpx"><view style="border:1px solid #e5e7eb;padding:14rpx;border-radius:12rpx">{{a}}</view></picker><input placeholder="任务标题" style="margin-top:10rpx;border:1px solid #e5e7eb;padding:14rpx;border-radius:12rpx" value="{{d}}" bindinput="{{e}}"/><input placeholder="地点（可选，默认可定位）" style="margin-top:10rpx;border:1px solid #e5e7eb;padding:14rpx;border-radius:12rpx" value="{{f}}" bindinput="{{g}}"/><input placeholder="图片地址（可选）" style="margin-top:10rpx;border:1px solid #e5e7eb;padding:14rpx;border-radius:12rpx" value="{{h}}" bindinput="{{i}}"/><picker mode="date" bindchange="{{k}}" style="margin-top:10rpx"><view style="border:1px solid #e5e7eb;padding:14rpx;border-radius:12rpx">截止日期：{{j}}</view></picker><button class="btn-primary" style="margin-top:12rpx" bindtap="{{l}}">创建任务</button><button style="margin-top:10rpx" bindtap="{{m}}">查看回忆归档</button></view></view>