<view style="{{'min-height:' + '100vh' + ';' + ('padding:' + '24rpx') + ';' + ('background:' + o)}}"><view wx:if="{{a}}" class="card"><view style="font-size:36rpx;font-weight:600">欢迎来到亲密空间</view><view class="hint" style="margin:12rpx 0 20rpx">先创建你们的双人空间，再邀请 TA 加入。</view><button class="btn-primary" bindtap="{{b}}">立即创建空间</button></view><block wx:else><view class="card"><view style="font-size:34rpx;font-weight:600">{{c}}</view><view class="hint" style="margin-top:8rpx">状态：{{d}}</view><view class="hint" style="margin-top:8rpx">亲密主题：{{e}}</view></view><view wx:if="{{f}}" class="card"><view class="hint">还差一步，邀请 TA 同意后空间生效。</view><button class="btn-primary" style="margin-top:12rpx" bindtap="{{g}}">去邀请</button></view><view wx:else class="card"><view style="font-size:30rpx;font-weight:600;margin-bottom:12rpx">快捷入口</view><button bindtap="{{h}}">共同事项类</button><button bindtap="{{i}}" style="margin-top:10rpx">创建任务</button><button bindtap="{{j}}" style="margin-top:10rpx">回忆归档</button><button bindtap="{{k}}" style="margin-top:10rpx">设置</button></view><view wx:if="{{l}}" class="card"><view style="font-size:30rpx;font-weight:600;margin-bottom:12rpx">待完成任务</view><view wx:if="{{m}}" class="hint">暂无任务，去创建一个吧。</view><view wx:for="{{n}}" wx:for-item="task" wx:key="d" style="border-top:1px solid #eef2ff;padding:14rpx 0"><view>{{task.a}}</view><view class="hint">截止：{{task.b}}</view><button size="mini" bindtap="{{task.c}}">标记完成</button></view></view></block></view>