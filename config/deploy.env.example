# 微信小程序基础
WECHAT_APPID=wx_your_appid
WECHAT_PROJECT_PATH=./dist/dev/mp-weixin
WECHAT_PRIVATE_KEY_PATH=./keys/private.your_appid.key
WECHAT_CI_ROBOT=1

# 版本信息
WECHAT_VERSION=0.1.0
WECHAT_UPLOAD_DESC=ci upload from mystwood

# 微信开发者工具 CLI（可选）
WECHAT_CLI_PATH=

# 云函数部署
WECHAT_CLOUD_ENV=your-cloud-env-id
WECHAT_CLOUD_FUNCTIONS_ROOT=./cloudfunctions
WECHAT_CLOUD_FUNCTION_NAMES=space-service,category-service,task-service

# H5 域名（可选，用于生成 CNAME）
WEBSITE_DOMAIN=
